# Delegado OS - Environment Configuration Example
# Copy this file to .env and customize values

# =============================================================================
# CORE SETTINGS
# =============================================================================
DELEGADO_VERSION=1.0.0
DELEGADO_MODE=auto
DELEGADO_LANGUAGE=en
DELEGADO_ENV=development

# =============================================================================
# PATHS
# =============================================================================
DELEGADO_KERNEL_PATH=./kernel
DELEGADO_WORKFLOWS_PATH=./workflows
DELEGADO_TEMPLATES_PATH=./templates
DELEGADO_MEMORY_PATH=./memory
DELEGADO_OBSIDIAN_PATH=./Obsidian
DELEGADO_PLUGINS_PATH=./plugins

# =============================================================================
# HELL METHOD (GRASP/GoF + TDD)
# =============================================================================
HELL_ENABLED=true
HELL_TDD_STRICT=true
HELL_GRASP_MODE=creator
HELL_GOF_PATTERNS=observer,strategy,factory,adapter,decorator

# =============================================================================
# AGENT BEHAVIOR
# =============================================================================
AGENT_AUTONOMY_LEVEL=medium
AGENT_SELF_CORRECT=true
AGENT_CONTEXT_WINDOW=8192
AGENT_MAX_ITERATIONS=50
AGENT_IDLE_TIMEOUT=300
AGENT_DEFAULT_MODE=guardian

# =============================================================================
# MEMORY & PERSISTENCE
# =============================================================================
MEMORY_BACKEND=obsidian
MEMORY_GRAPH_ENABLED=true
MEMORY_AUTO_INDEX=true
MEMORY_RETENTION_DAYS=90
MEMORY_SYNC_INTERVAL=60

# =============================================================================
# WORKFLOW SETTINGS
# =============================================================================
WORKFLOW_DEFAULT=bmad
WORKFLOW_BMAD_STEPS=analyze,implement,verify,deploy
WORKFLOW_GSD_ENABLED=true
WORKFLOW_OPENSPEC_ENABLED=true
WORKFLOW_FAIL_FAST=true

# =============================================================================
# OBSIDIAN INTEGRATION
# =============================================================================
OBSIDIAN_VAULT_PATH=./Obsidian
OBSIDIAN_SYNC_ENABLED=true
OBSIDIAN_SYNC_INTERVAL=60
OBSIDIAN_DAILY_NOTES=true
OBSIDIAN_TEMPLATES_PATH=./templates/obsidian
OBSIDIAN_AUTO_COMMIT=true

# =============================================================================
# LOGGING & OBSERVABILITY
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=./logs/delegado.log
LOG_ROTATION=true
LOG_MAX_SIZE=100M
LOG_MAX_FILES=10
METRICS_ENABLED=true
METRICS_PORT=9090
METRICSDetailed=false

# =============================================================================
# API SERVER (api-server plugin)
# =============================================================================
API_SERVER_ENABLED=false
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8080
API_SERVER_WORKERS=4
API_SERVER_TIMEOUT=300
API_SERVER_CORS_ENABLED=true
API_SERVER_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# AUTHENTICATION
# =============================================================================
DELEGADO_API_TOKEN=your-secure-api-token-here
DELEGADO_JWT_SECRET=your-jwt-secret-here
DELEGADO_JWT_ALGORITHM=HS256
DELEGADO_JWT_EXPIRATION=3600

# =============================================================================
# EXTERNAL INTEGRATIONS
# =============================================================================
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_ORG=delegado-os
GITHUB_REPO=delegado-os
GITHUB_DEFAULT_BRANCH=main

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXX/XXXXX/XXXXXXXXXXXX
SLACK_CHANNEL=#delegado
SLACK_NOTIFY_ON=task.completed,task.failed,agent.started,agent.stopped

NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINEAR_TEAM_ID=TEAM-XXX

# =============================================================================
# PLUGIN CONFIGURATIONS
# =============================================================================

# Kubernetes Plugin
KUBERNETES_ENABLED=false
KUBERNETES_CONTEXT=minikube
KUBERNETES_NAMESPACE=delegado
KUBERNETES_DEPLOYMENT_NAME=delegado-os

# Database Plugin
DATABASE_ENABLED=false
DATABASE_URL=postgresql://localhost:5432/delegado
DATABASE_POOL_SIZE=10
DATABASE_TIMEOUT=30

# Container Plugin
CONTAINER_ENABLED=false
CONTAINER_RUNTIME=docker
CONTAINER_NETWORK=delegado-net

# Monitoring Plugin
MONITORING_ENABLED=true
MONITORING_PROMETHEUS_URL=http://localhost:9090
MONITORING_CHECK_INTERVAL=30

# Backup Plugin
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_DESTINATION=/backups
BACKUP_RETENTION_DAYS=30

# Webhook Plugin
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://example.com/webhook
WEBHOOK_EVENTS=task.completed,task.failed
WEBHOOK_RETRY=3

# Scheduler Plugin
SCHEDULER_ENABLED=false
SCHEDULER_DEFAULT_TIMEZONE=UTC

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================
MAX_PARALLEL_TASKS=4
TASK_TIMEOUT_SECONDS=300
TASK_BATCH_SIZE=10
WORKER_THREADS=2

CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=512

CONTEXT_AUTO_TRIM=true
CONTEXT_TRIM_THRESHOLD=0.9
CONTEXT_TRIM_PRESERVE_RECENT=0.3

# =============================================================================
# SECURITY
# =============================================================================
SECURITY_SCAN_ON_START=true
SECURITY_SEVERITY_THRESHOLD=medium
SECURITY_AUTO_REMEDIATE=false

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Encryption
ENCRYPTION_ENABLED=true
ENCRYPTION_ALGORITHM=AES-256-GCM
ENCRYPTION_KEY_ENV=DELEGADO_ENCRYPTION_KEY

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
DEBUG=false
DEBUG_PLUGINS=false
DEBUG_MEMORY=false
DEV_MODE_AUTO_RELOAD=true
DEV_MODE_MOCK_EXTERNAL=false

# =============================================================================
# TESTING SETTINGS
# =============================================================================
TEST_MODE=false
TEST_FIXTURES_PATH=./tests/fixtures
TEST_COVERAGE_ENABLED=false
TEST_PARALLEL_WORKERS=4

# =============================================================================
# ADMINISTRATION
# =============================================================================
ADMIN_TOKEN=admin-secret-token-change-in-production
ADMIN_EMAIL=admin@delegado-os.local
ADMIN_NOTIFY_ON_ERRORS=true

# Maintenance
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="System under maintenance"
