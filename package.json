{
  "name": "@delegado/os-delegate",
  "version": "2.0.11",
  "description": "AI Agent OS — HELL-Centric Meta-Prompting with Autonomous CLI Agent",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "chmod +x delegado.sh && echo 'Build OK: all scripts are executable'",
    "test": "node tests/meta-prompting.test.js",
    "test:watch": "nodemon --exec 'npm test'",
    "lint": "eslint . || true",
    "delegado": "./delegado.sh",
    "hell:spec": "node scripts/hell/hell-cycle.js spec",
    "hell:tdd": "node scripts/hell/hell-cycle.js tdd",
    "hell:refactor": "node scripts/hell/hell-cycle.js refactor",
    "hell:audit": "node scripts/hell/hell-cycle.js audit",
    "hell:milestone": "node scripts/hell/hell-cycle.js milestone",
    "obsidian:sync": "node scripts/obsidian/obsidian-sync.js sync",
    "ci:validate": "node scripts/ci/validate.js --all",
    "plugin": "node plugin/plugin-loader.js",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "ai-agent",
    "meta-prompting",
    "hell-method",
    "tdd",
    "grasp",
    "gof-patterns",
    "delegado-os",
    "agent-os"
  ],
  "author": "77mdias",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/77mdias/delegate-os.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "nodemon": "^3.0.0"
  }
}
